{
  "manifest_version": 3,
  "name": "QLINK Bridge",
  "version": "0.1.0",
  "description": "큐링크가 사용자의 웹 AI 세션(Gemini 등)을 통해 링크를 요약하도록 하는 브릿지 확장프로그램",
  "permissions": ["scripting", "storage"],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://*.qlink.app/*",
    "http://localhost:*/*"
  ],
  "background": { "service_worker": "background.js", "type": "module" },
  "content_scripts": [
    {
      "matches": ["https://*.qlink.app/*", "http://localhost:*/*"],
      "js": ["content/qlink-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content/gemini.js"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
